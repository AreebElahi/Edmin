  courseoffering                           courseoffering?            @relation(fields: [courseofferingid], references: [courseofferingid])
  user_academicchatsession_facultyidTouser user                       @relation("academicchatsession_facultyidTouser", fields: [facultyid], references: [userid], onDelete: Cascade)
  user_academicchatsession_studentidTouser user                       @relation("academicchatsession_studentidTouser", fields: [studentid], references: [userid], onDelete: Cascade)

  @@unique([studentid, facultyid, courseofferingid])
}

model complaint {
  complaintid                       Int                 @id @default(autoincrement())
  tokenid                           String              @unique @db.VarChar(50)
  createdbyid                       Int
  subject                           String              @db.VarChar(255)
  description                       String
  status                            complaint_status    @default(OPEN)
  createdat                         DateTime            @default(now()) @db.Timestamp(6)
  updatedat                         DateTime            @default(now()) @db.Timestamp(6)
  deletedat                         DateTime?
  assignedtoid                      Int?
  priority                          complaint_priority  @default(MEDIUM)
  sladuedate                        DateTime?
  user_complaint_assignedtoidTouser user?               @relation("complaint_assignedtoidTouser", fields: [assignedtoid], references: [userid])
  user_complaint_createdbyidTouser  user                @relation("complaint_createdbyidTouser", fields: [createdbyid], references: [userid], onDelete: Cascade)
  complaintauditlog                 complaintauditlog[]
  complaintmessage                  complaintmessage[]
}

model complaintauditlog {
  id          Int       @id @default(autoincrement())
  complaintid Int
  userid      Int
  action      String    @db.VarChar(50)
  oldvalue    String?
  newvalue    String?
  createdat   DateTime  @default(now()) @db.Timestamp(6)
  complaint   complaint @relation(fields: [complaintid], references: [complaintid], onDelete: Cascade)
  user        user      @relation(fields: [userid], references: [userid], onDelete: Cascade)
}

model complaintmessage {
  complaintmessageid Int       @id @default(autoincrement())
  complaintid        Int
  senderid           Int
  message            String
  sentat             DateTime  @default(now()) @db.Timestamp(6)
  complaint          complaint @relation(fields: [complaintid], references: [complaintid], onDelete: Cascade)
  user               user      @relation(fields: [senderid], references: [userid], onDelete: Cascade)
}

