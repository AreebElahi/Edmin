generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admindocumentattachment {
  admindocumentattachmentid Int                    @id @default(autoincrement())
  createdat                 DateTime               @default(now()) @db.Timestamp(6)
  deletedat                 DateTime?
  documentcategory          document_category_full
  filename                  String?                @db.VarChar(255)
  filestorageurl            String?                @db.VarChar(500)
  isactive                  Boolean                @default(true)
  isverified                Boolean                @default(false)
  updatedat                 DateTime               @default(now()) @db.Timestamp(6)
  uploadedtimestamp         DateTime               @default(now()) @db.Timestamp(6)
  userid                    Int
  verificationtimestamp     DateTime?              @db.Timestamp(6)
  verifiedbyuserid          Int?
  securefiletoken           String                 @default(dbgenerated("gen_random_uuid()")) @db.Uuid
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model adminprofile {
